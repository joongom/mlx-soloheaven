# MLX SoloHeaven Configuration
# All settings can also be passed as CLI arguments (run `mlx-soloheaven --help`)

# Required: path to the MLX model directory
SOLOHEAVEN_MODEL=/path/to/your/mlx-model

# Server
SOLOHEAVEN_HOST=0.0.0.0
SOLOHEAVEN_PORT=8000

# Generation defaults
SOLOHEAVEN_TEMPERATURE=0.6
SOLOHEAVEN_MAX_TOKENS=32768
SOLOHEAVEN_THINKING_BUDGET=8192

# Cache budgets (evict LRU when exceeded, no time-based TTL)
SOLOHEAVEN_MEMORY_BUDGET_GB=200
SOLOHEAVEN_DISK_BUDGET_GB=1000

# Data directory (SQLite DB + KV cache files)
SOLOHEAVEN_DATA_DIR=./data

# MLX SoloHeaven Configuration
# Copy this file to .env and edit for your setup.
# All settings can also be passed as CLI arguments (run `mlx-soloheaven --help`).
# CLI args take precedence over env vars.

# ============================================================
# Model
# ============================================================

# Single model (use ONE of MODEL or MODELS, not both)
SOLOHEAVEN_MODEL=/path/to/your/mlx-model

# Multi-model: comma-separated, optional alias= prefix, :no_think_tag suffix
# SOLOHEAVEN_MODELS=qwen-122b=/path/to/Qwen3.5-122B-A10B-8bit,/path/to/Qwen3-Coder-Next-8bit:no_think_tag

# ============================================================
# Server
# ============================================================

SOLOHEAVEN_HOST=0.0.0.0
SOLOHEAVEN_PORT=8000

# ============================================================
# Sampling Defaults
# ============================================================
# These are the server-wide defaults applied when the client
# does not specify a value in the API request.
#
#   temperature   — Randomness. 0 = deterministic, higher = more creative.
#   top_p         — Nucleus sampling. 1.0 = off, lower = focus on likely tokens.
#   min_p         — Min probability threshold (relative to top token). 0.0 = off.
#   top_k         — Limit candidate tokens. 0 = off.
#   repetition_penalty — Penalize repeated tokens. 1.0 = off, >1.0 = discourage.
#
# All values can be overridden per-request via the OpenAI-compatible API:
#   { "temperature": 0.8, "top_p": 0.95, "top_k": 40, ... }

SOLOHEAVEN_TEMPERATURE=0.6
SOLOHEAVEN_TOP_P=1.0
SOLOHEAVEN_MIN_P=0.0
SOLOHEAVEN_TOP_K=0
SOLOHEAVEN_REPETITION_PENALTY=1.0

# ============================================================
# Generation
# ============================================================

# Max output tokens per request
SOLOHEAVEN_MAX_TOKENS=32768

# Thinking budget: max tokens inside <think>...</think> before forcing </think>.
# 0 = unlimited (model decides when to stop thinking).
SOLOHEAVEN_THINKING_BUDGET=8192

# ============================================================
# Cache Budget
# ============================================================
# No time-based TTL — evicts LRU sessions only when budget is exceeded.
#
#   memory_budget_gb — Total in-memory KV cache across all sessions.
#   disk_budget_gb   — Total on-disk KV cache (safetensors persistence).
#
# Example for Mac Studio M3 Ultra 512GB with Qwen3.5-397B (~160GB model weight):
#   memory: 50GB = ~12 sessions (397B) or ~50 sessions (122B)
#   disk: 100GB = ~24 sessions (397B) or ~100 sessions (122B)

SOLOHEAVEN_MEMORY_BUDGET_GB=200
SOLOHEAVEN_DISK_BUDGET_GB=100

# ============================================================
# Data & Storage
# ============================================================

# Directory for SQLite DB + KV cache files
SOLOHEAVEN_DATA_DIR=./data

# ============================================================
# Flags
# ============================================================

# Keep Metal GPU warm with periodic micro-computations (prevents idle penalty)
SOLOHEAVEN_GPU_KEEPALIVE=false

# Show debug-level logs (cache details, lock timing, etc.)
SOLOHEAVEN_VERBOSE=false
